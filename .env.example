AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_BASE_URL=
AI_API_KEY=
NEXT_PUBLIC_APP_NAME=സംസ്കൃതം ഗുരു

# Gemini key (used for vision + voice transcription).
# Falls back to AI_API_KEY if unset.
# GEMINI_API_KEY=

# Voice transcription model (defaults to gemini-2.5-flash).
# TRANSCRIBE_MODEL=gemini-2.5-flash

# DeepSeek text mode:
# AI_PROVIDER=deepseek
# AI_MODEL=deepseek-chat
# AI_BASE_URL=https://api.deepseek.com
# AI_API_KEY=your_deepseek_api_key
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Sarvam AI: primary for Malayalam STT, Malayalam TTS, and OCR/document extraction.
# SARVAM_API_KEY=
# SARVAM_BASE_URL=https://api.sarvam.ai
# SARVAM_STT_MODEL=saaras:v3
# SARVAM_TTS_MODEL=bulbul:v3
# SARVAM_TTS_SPEAKER=kavitha

# OpenAI: fallback for transcription, OCR/vision, tutor, and TTS.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_TUTOR_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral

# Gemini fallbacks.
# GEMINI_OCR_MODEL=gemini-2.5-flash-lite
